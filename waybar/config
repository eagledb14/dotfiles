{
    "layer": "bottom",
    "position": "top",
    "height": 28,
    "spacing": 5,
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["hyprland/window"],
    "modules-right": [ "clock", "pulseaudio", "battery", "tray"],
    "hyprland/workspaces": {
            "format": "{icon}",
            "on-scroll-up": "hyprctl dispatch \"hl.dsp.focus({workspace = 'e+1'})\" > /dev/null",
            "on-scroll-down": "hyprctl dispatch \"hl.dsp.focus({workspace = 'e-1'})\" > /dev/null",
    },
    "hyprland/window": {
            "max-length": 200,
            "separate-outputs": true
    },
    "clock": {
        "format": "{:%a %b %d, %H:%M} |",
        "tooltip": false
    },
    "pulseaudio": {
        "format": "Volume: {volume}% |",
        "format-muted": "Muted: {volume}% |",
        "scroll-step": 1,
        "on-click": "sh -c '~/.config/waybar/cycle-sink.py next'",
        "on-click-right": "sh -c '~/.config/waybar/cycle-sink.py prev'"
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "bat":"BAT0",
        "format": "Bat: {capacity}% |",
        "format-charging": "Bat Ch: {capacity}% |",
        "format-plugged": "Bat: {capacity}% |",
        "format-discharging": "Bat: {capacity}% |",
        "format-alt": "Bat: {time}",
    },
}
